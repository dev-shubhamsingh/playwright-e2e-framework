{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    // This is a test project — nothing is compiled to dist; every runner
    // (Playwright, ts-jest, k6) transpiles on its own. noEmit reflects that
    // and unlocks allowImportingTsExtensions, which the k6 scripts need since
    // k6's module loader requires explicit .ts extensions on local imports.
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "outDir": "./dist",
    "rootDir": ".",
    "paths": {
      "@core/*": ["./src/core/*"],
      "@config/*": ["./src/core/config/*"],
      "@saucedemo/*": ["./src/saucedemo/*"],
      "@dummyjson/*": ["./src/dummyjson/*"],
      "@shared/*": ["./src/shared/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*", "tars/**/*", "playwright.config.ts"],
  "exclude": ["node_modules", "dist"]
}
