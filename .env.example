# Copy this file to .env and override any value you need.
#   cp .env.example .env
#
# Every variable below has a sensible public default (see
# src/core/config/env.ts), so the suite runs with no .env at all. Uncomment a
# line only to override its default. Never commit your real .env.

# ── SauceDemo UI module ───────────────────────────────────────────────────
# BASE_URL=https://www.saucedemo.com
# TEST_USER=standard_user
# TEST_PASSWORD=secret_sauce

# ── DummyJSON API module ──────────────────────────────────────────────────
# API_BASE_URL=https://dummyjson.com
# DUMMYJSON_USERNAME=emilys
# DUMMYJSON_PASSWORD=emilyspass
